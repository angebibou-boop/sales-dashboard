  </div>
</div>

<!-- Main app -->
<div id="app">
  <header class="header">
    <div class="header-logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
    </div>
    <div class="header-text">
      <div class="title">Meta Ads Dashboard</div>
      <div class="subtitle">Ad performance &amp; spend analytics</div>
    </div>
    <div class="filter-group">
      <label>From</label>
      <input type="date" id="dateFrom">
      <span class="filter-sep">→</span>
      <label>To</label>
      <input type="date" id="dateTo">
    </div>
    <button class="btn btn-refresh" id="refetchBtn">
      <svg class="refresh-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      Refresh
    </button>
    <div class="header-spacer"></div>
    <a href="index.html" class="btn btn-ghost" style="text-decoration:none;">← Sales Dashboard</a>
    <div class="user-chip">
      <div class="user-avatar" id="userAvatar">U</div>
      <span id="userEmail"></span>
    </div>
    <button class="btn btn-ghost" id="signOutBtn">Sign Out</button>
  </header>

  <div class="main">
    <!-- KPIs -->
    <div class="section-head" style="margin-bottom:14px;">Overview</div>
    <div class="kpi-grid" id="kpiGrid">
      <div class="kpi-card k-blue"><div class="kpi-label">Total Spend</div><div class="kpi-value">—</div></div>
      <div class="kpi-card k-cyan"><div class="kpi-label">Impressions</div><div class="kpi-value">—</div></div>
      <div class="kpi-card k-green"><div class="kpi-label">Clicks</div><div class="kpi-value">—</div></div>
      <div class="kpi-card k-pink"><div class="kpi-label">Avg CTR</div><div class="kpi-value">—</div></div>
      <div class="kpi-card k-gold"><div class="kpi-label">Avg CPM</div><div class="kpi-value">—</div></div>
      <div class="kpi-card k-purple"><div class="kpi-label">Avg CPC</div><div class="kpi-value">—</div></div>
    </div>

    <!-- Daily chart -->
    <div class="chart-card">
      <div class="chart-title">Daily Spend &amp; Clicks</div>
      <div class="chart-wrap"><canvas id="insightChart"></canvas></div>
    </div>

    <!-- Campaigns table -->
    <div class="table-card">
      <div class="table-toolbar">
        <div class="table-title">Campaigns <span class="count" id="campaignCount">0</span></div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Campaign</th>
              <th>Status</th>
              <th style="text-align:right;">Spend</th>
              <th style="text-align:right;">Impressions</th>
              <th style="text-align:right;">Clicks</th>
              <th style="text-align:right;">CTR</th>
              <th style="text-align:right;">CPM</th>
              <th style="text-align:right;">CPC</th>
            </tr>
          </thead>
          <tbody id="campaignTbody"><tr><td colspan="8" class="empty">Loading…</td></tr></tbody>
        </table>
      </div>
    </div>

    <!-- Ad Sets table -->
    <div class="table-card">
      <div class="table-toolbar">
        <div class="table-title">Ad Sets <span class="count" id="adsetCount">0</span></div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Ad Set</th>
              <th>Status</th>
              <th>Objective</th>
              <th style="text-align:right;">Daily Budget</th>
              <th style="text-align:right;">Lifetime Budget</th>
            </tr>
          </thead>
          <tbody id="adsetTbody"><tr><td colspan="5" class="empty">Loading…</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
const SUPABASE_URL    = "https://pojqljrhhtnigyrtzdzz.supabase.co";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBvanFsanJoaHRuaWd5cnR6ZHp6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MTA3ODMsImV4cCI6MjA5MTM4Njc4M30.PcSBDqOzbiZxZ7IAs5efqx0gsAlAG0cj3GqUOkAmxos";
const META_ADS_BASE  = SUPABASE_URL + "/functions/v1/meta-ads";

const supa = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
  auth: { persistSession: true, detectSessionInUrl: true, autoRefreshToken: true }
});

function setState(s) { document.body.dataset.state = s; }

let currentSession = null;
let insightChart = null;

// ── Auth ─────────────────────────────────────────────────
async function initAuth() {
  const { data: { session } } = await supa.auth.getSession();
  if (session) { onAuthed(session); return; }
  setState('login');
  supa.auth.onAuthStateChange((_e, sess) => {
    if (sess) onAuthed(sess);
    else setState('login');
  });
}

async function onAuthed(session) {
  currentSession = session;
  const email = session.user.email || '';
  document.getElementById('userEmail').textContent = email;
  document.getElementById('userAvatar').textContent = (email[0] || 'U').toUpperCase();

  // Role check
  const perms = session.user.app_metadata?.permissions ?? [];
  const isAdmin = session.user.app_metadata?.is_admin ?? false;
  if (!isAdmin && !perms.includes('marketing')) {
    setState('denied');
    return;
  }

  setState('dashboard');
  setDefaultDates();
  await loadAll();
}

function setDefaultDates() {
  const to   = new Date();
  const from = new Date(Date.now() - 30 * 86400000);
  document.getElementById('dateTo').value   = to.toISOString().slice(0, 10);
  document.getElementById('dateFrom').value = from.toISOString().slice(0, 10);
}

// ── Data loading ──────────────────────────────────────────
async function apiFetch(api) {
  const from = document.getElementById('dateFrom').value;
  const to   = document.getElementById('dateTo').value;
  const params = new URLSearchParams({ api, from, to });
  const r = await fetch(META_ADS_BASE + '?' + params, {
    cache: 'no-store',
    headers: { Authorization: 'Bearer ' + currentSession.access_token }
  });
  if (r.status === 401) { await supa.auth.signOut(); return null; }
  if (!r.ok) {
    const j = await r.json().catch(() => ({}));
    throw new Error(j.error || 'HTTP ' + r.status);
  }
  return r.json();
}

async function loadAll() {
  const btn = document.getElementById('refetchBtn');
  btn.classList.add('spinning');

  try {
    const [insights, campaigns, adsets] = await Promise.all([
      apiFetch('insights'),
      apiFetch('campaigns'),
      apiFetch('adsets'),
    ]);
    if (insights)  renderInsights(insights);
    if (campaigns) renderCampaigns(campaigns, insights || []);
    if (adsets)    renderAdsets(adsets);
  } catch (err) {
    document.getElementById('kpiGrid').innerHTML =
      '<div class="kpi-card" style="grid-column:1/-1;"><div class="kpi-label error">Error: ' + (err.message || err) + '</div></div>';
    console.error(err);
  } finally {
    btn.classList.remove('spinning');
  }
}

// ── Formatters ────────────────────────────────────────────
const fmtMoney = v => '$' + Number(v || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const fmtNum   = v => Number(v || 0).toLocaleString();
const fmtPct   = v => (Number(v || 0) * 100).toFixed(2) + '%';  // Meta CTR is 0-100 already sometimes
const safePct  = v => { const n = Number(v || 0); return n > 1 ? n.toFixed(2) + '%' : (n * 100).toFixed(2) + '%'; };
const fmtCur   = v => '$' + Number(v || 0).toFixed(2);

function statusBadge(s) {
  const cls = s === 'ACTIVE' ? 'status-active' : s === 'PAUSED' ? 'status-paused' : 'status-other';
  return `<span class="status-badge ${cls}">${s}</span>`;
}

// ── Render insights (KPIs + chart) ────────────────────────
function renderInsights(rows) {
  let totalSpend = 0, totalImpressions = 0, totalClicks = 0;
  const byDate = {};

  rows.forEach(r => {
    totalSpend       += Number(r.spend || 0);
    totalImpressions += Number(r.impressions || 0);
    totalClicks      += Number(r.clicks || 0);
    const d = r.date_start || r.date_stop || '';
    if (d) {
      byDate[d] = byDate[d] || { spend: 0, clicks: 0 };
      byDate[d].spend  += Number(r.spend || 0);
      byDate[d].clicks += Number(r.clicks || 0);
    }
  });

  const avgCTR = totalImpressions > 0 ? (totalClicks / totalImpressions) * 100 : 0;
  const avgCPM = totalImpressions > 0 ? (totalSpend / totalImpressions) * 1000 : 0;
  const avgCPC = totalClicks > 0 ? totalSpend / totalClicks : 0;

  // KPI cards
  const kpis = [
    { cls: 'k-blue',   label: 'Total Spend',   value: fmtMoney(totalSpend) },
    { cls: 'k-cyan',   label: 'Impressions',   value: fmtNum(totalImpressions) },
    { cls: 'k-green',  label: 'Clicks',        value: fmtNum(totalClicks) },
    { cls: 'k-pink',   label: 'Avg CTR',       value: avgCTR.toFixed(2) + '%' },
    { cls: 'k-gold',   label: 'Avg CPM',       value: fmtCur(avgCPM) },
    { cls: 'k-purple', label: 'Avg CPC',       value: fmtCur(avgCPC) },
  ];
  document.getElementById('kpiGrid').innerHTML = kpis.map(k =>
    `<div class="kpi-card ${k.cls}">
      <div class="kpi-label">${k.label}</div>
      <div class="kpi-value">${k.value}</div>
    </div>`
  ).join('');

  // Chart
  const dates  = Object.keys(byDate).sort();
  const spend  = dates.map(d => byDate[d].spend);
  const clicks = dates.map(d => byDate[d].clicks);

  const fmtLabel = d => { const [y,m,day] = d.split('-'); return `${m}/${day}`; };

  if (insightChart) insightChart.destroy();
  const ctx = document.getElementById('insightChart').getContext('2d');
  const blueGrad = ctx.createLinearGradient(0, 0, 0, 280);
  blueGrad.addColorStop(0, 'rgba(24,119,242,0.8)');
  blueGrad.addColorStop(1, 'rgba(24,119,242,0.3)');
  const pinkGrad = ctx.createLinearGradient(0, 0, 0, 280);
  pinkGrad.addColorStop(0, 'rgba(225,48,108,0.8)');
  pinkGrad.addColorStop(1, 'rgba(225,48,108,0.3)');

  insightChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: dates.map(fmtLabel),
      datasets: [
        {
          label: 'Spend ($)',
          data: spend,
          backgroundColor: blueGrad,
          borderRadius: 5,
          yAxisID: 'ySpend',
          order: 2,
        },
        {
          label: 'Clicks',
          data: clicks,
          type: 'line',
          borderColor: '#e1306c',
          backgroundColor: 'rgba(225,48,108,0.1)',
          borderWidth: 2,
          pointRadius: 3,
          pointBackgroundColor: '#e1306c',
          tension: 0.35,
          fill: false,
          yAxisID: 'yClicks',
          order: 1,
        },
      ],
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { labels: { color: '#8890b0', font: { size: 11 } } },
        tooltip: {
          backgroundColor: '#1a1e30', borderColor: '#252840', borderWidth: 1,
          titleColor: '#e8eaf4', bodyColor: '#8890b0', padding: 10,
          callbacks: {
            label: ctx => ctx.dataset.label === 'Spend ($)'
              ? ' $' + ctx.parsed.y.toFixed(2)
              : ' ' + ctx.parsed.y.toLocaleString() + ' clicks',
          },
        },
      },
      scales: {
        x: { grid: { color: 'rgba(37,40,64,0.6)' }, ticks: { color: '#4a5070', font: { size: 10 } } },
        ySpend:  { position: 'left',  grid: { color: 'rgba(37,40,64,0.6)' }, ticks: { color: '#4a5070', font: { size: 10 }, callback: v => '$' + v.toLocaleString() } },
        yClicks: { position: 'right', grid: { display: false }, ticks: { color: '#4a5070', font: { size: 10 }, callback: v => v.toLocaleString() } },
      },
    },
  });
}

// ── Render campaigns ──────────────────────────────────────
function renderCampaigns(campaigns, insights) {
  document.getElementById('campaignCount').textContent = campaigns.length;

  // Aggregate insights by campaign
  const byId = {};
  insights.forEach(r => {
    const id = r.campaign_id;
    if (!id) return;
    byId[id] = byId[id] || { spend: 0, impressions: 0, clicks: 0 };
    byId[id].spend       += Number(r.spend || 0);
    byId[id].impressions += Number(r.impressions || 0);
    byId[id].clicks      += Number(r.clicks || 0);
  });

  if (!campaigns.length) {
    document.getElementById('campaignTbody').innerHTML = '<tr><td colspan="8" class="empty">No campaigns found.</td></tr>';
    return;
  }

  document.getElementById('campaignTbody').innerHTML = campaigns.map(c => {
    const ins = byId[c.id] || { spend: 0, impressions: 0, clicks: 0 };
    const ctr = ins.impressions > 0 ? (ins.clicks / ins.impressions) * 100 : 0;
    const cpm = ins.impressions > 0 ? (ins.spend / ins.impressions) * 1000 : 0;
    const cpc = ins.clicks > 0 ? ins.spend / ins.clicks : 0;
    return `<tr>
      <td style="color:var(--text); font-weight:600; max-width:220px; overflow:hidden; text-overflow:ellipsis;">${c.name || '—'}</td>
      <td>${statusBadge(c.status || '')}</td>
      <td class="num">${fmtMoney(ins.spend)}</td>
      <td class="num">${fmtNum(ins.impressions)}</td>
      <td class="num">${fmtNum(ins.clicks)}</td>
      <td class="num">${ctr.toFixed(2)}%</td>
      <td class="num">${fmtCur(cpm)}</td>
      <td class="num">${fmtCur(cpc)}</td>
    </tr>`;
  }).join('');
}

// ── Render ad sets ────────────────────────────────────────
function renderAdsets(adsets) {
  document.getElementById('adsetCount').textContent = adsets.length;
  if (!adsets.length) {
    document.getElementById('adsetTbody').innerHTML = '<tr><td colspan="5" class="empty">No ad sets found.</td></tr>';
    return;
  }
  const fmtBudget = v => v && v !== '0' ? fmtMoney(Number(v) / 100) : '—';
  document.getElementById('adsetTbody').innerHTML = adsets.map(a => `<tr>
    <td style="color:var(--text); font-weight:600;">${a.name || '—'}</td>
    <td>${statusBadge(a.status || '')}</td>
    <td style="color:var(--text-muted);">${(a.optimization_goal || '').replace(/_/g, ' ') || '—'}</td>
    <td class="num">${fmtBudget(a.daily_budget)}/day</td>
    <td class="num">${fmtBudget(a.lifetime_budget)}</td>
  </tr>`).join('');
}

// ── Event listeners ───────────────────────────────────────
document.getElementById('loginForm').addEventListener('submit', async e => {
  e.preventDefault();
  const email    = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;
  const errEl    = document.getElementById('loginError');
  const btn      = document.getElementById('sendBtn');
  errEl.textContent = '';
  btn.disabled = true; btn.textContent = 'Signing in…';
  try {
    const { data, error } = await supa.auth.signInWithPassword({ email, password });
    if (error) throw error;
    onAuthed(data.session);
  } catch (err) {
    errEl.textContent = err.message || 'Invalid credentials';
  } finally {
    btn.disabled = false; btn.textContent = 'Sign In';
  }
});

document.getElementById('signOutBtn').addEventListener('click', async () => {
  await supa.auth.signOut();
  setState('login');
});

document.getElementById('refetchBtn').addEventListener('click', loadAll);

document.getElementById('dateFrom').addEventListener('change', loadAll);
document.getElementById('dateTo').addEventListener('change', loadAll);

// ── Boot ──────────────────────────────────────────────────
setState('loading');
initAuth();
</script>
</body>
</html>
