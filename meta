<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meta Ads Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>
  :root {
    --bg: #0d0f1a;
    --surface: #131627;
    --surface2: #1a1e30;
    --surface3: #1e2336;
    --border: #252840;
    --border-light: #2e3352;
    --text: #e8eaf4;
    --text-muted: #8890b0;
    --text-dim: #4a5070;
    --blue: #6b9eff;
    --blue-bg: rgba(107,158,255,0.12);
    --green: #34d399;
    --green-bg: rgba(52,211,153,0.12);
    --red: #f87171;
    --red-bg: rgba(248,113,113,0.12);
    --gold: #fbbf24;
    --gold-bg: rgba(251,191,36,0.12);
    --purple: #a78bfa;
    --purple-bg: rgba(167,139,250,0.12);
    --cyan: #22d3ee;
    --cyan-bg: rgba(34,211,238,0.12);
    --pink: #f472b6;
    --pink-bg: rgba(244,114,182,0.12);
    --bg-grad: linear-gradient(160deg, #0d0f1a 0%, #101220 50%, #0d0f1a 100%);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', Roboto, sans-serif;
    background: var(--bg-grad); background-attachment: fixed;
    color: var(--text); min-height: 100vh; -webkit-font-smoothing: antialiased;
  }

  /* ── Auth screens ─────────────────────────────────────── */
  .full-center {
    min-height: 100vh; display: flex; align-items: center;
    justify-content: center; padding: 20px;
  }
  .auth-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 20px; padding: 36px 32px; width: 100%; max-width: 400px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
  }
  .auth-icon {
    width: 56px; height: 56px; border-radius: 16px; margin: 0 auto 20px;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #1877f2 0%, #e1306c 100%);
    box-shadow: 0 8px 24px rgba(24,119,242,0.4);
  }
  .auth-card h1 { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 6px; }
  .auth-card .sub { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 24px; }
  .auth-input {
    width: 100%; background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px; padding: 12px 14px; color: var(--text); font-size: 0.92rem;
    outline: none; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .auth-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px var(--blue-bg); }
  .auth-btn {
    width: 100%; margin-top: 12px;
    background: linear-gradient(135deg, #1877f2 0%, #e1306c 100%);
    border: none; border-radius: 10px; padding: 12px 16px; color: #fff;
    font-size: 0.92rem; font-weight: 600; cursor: pointer;
    transition: transform 0.1s, box-shadow 0.15s;
    box-shadow: 0 6px 20px rgba(24,119,242,0.3);
  }
  .auth-btn:hover { transform: translateY(-1px); }
  .auth-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .auth-error { color: var(--red); font-size: 0.78rem; margin-top: 8px; min-height: 1em; }
  .spinner {
    width: 40px; height: 40px; border: 3px solid var(--border);
    border-top-color: var(--blue); border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── State visibility ─────────────────────────────────── */
  body[data-state="loading"] #app,
  body[data-state="loading"] #login,
  body[data-state="loading"] #denied,
  body[data-state="dashboard"] #login,
  body[data-state="dashboard"] #boot,
  body[data-state="dashboard"] #denied,
  body[data-state="login"] #app,
  body[data-state="login"] #boot,
  body[data-state="login"] #denied,
  body[data-state="denied"] #app,
  body[data-state="denied"] #boot,
  body[data-state="denied"] #login { display: none; }
  body[data-state="loading"] #boot { display: flex; }
  body[data-state="login"] #login { display: flex; }
  body[data-state="denied"] #denied { display: flex; }
  body[data-state="dashboard"] #app { display: block; }

  /* ── Header ───────────────────────────────────────────── */
  .header {
    display: flex; align-items: center; gap: 14px; padding: 16px 28px;
    background: rgba(19,22,39,0.9); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100;
    flex-wrap: wrap;
  }
  .header-logo {
    width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
    background: linear-gradient(135deg, #1877f2 0%, #e1306c 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .header-text .title {
    font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em;
    background: linear-gradient(135deg, #e8eaf4 0%, #a8b0d0 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .header-text .subtitle { color: var(--text-muted); font-size: 0.75rem; margin-top: 1px; }
  .header-spacer { flex: 1; }
  .filter-group {
    display: flex; align-items: center; gap: 8px;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 12px; padding: 6px 10px;
  }
  .filter-group label { font-size: 0.7rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .filter-sep { color: var(--text-dim); }
  .filter-group input[type="date"] {
    background: var(--bg); border: 1px solid var(--border); border-radius: 7px;
    padding: 6px 10px; color: var(--text); font-size: 0.78rem; outline: none;
    color-scheme: dark; width: 138px;
  }
  .filter-group input[type="date"]:focus { border-color: var(--blue); }
  .btn {
    border: none; border-radius: 9px; padding: 8px 14px; font-size: 0.78rem;
    font-weight: 600; cursor: pointer; transition: all 0.15s; display: inline-flex;
    align-items: center; gap: 6px;
  }
  .btn-ghost { background: var(--surface2); color: var(--text-muted); border: 1px solid var(--border); }
  .btn-ghost:hover { color: var(--text); border-color: var(--border-light); }
  .btn-primary {
    background: linear-gradient(135deg, #1877f2 0%, #e1306c 100%);
    color: #fff; box-shadow: 0 4px 12px rgba(24,119,242,0.25);
  }
  .btn-primary:hover { transform: translateY(-1px); }
  .btn-refresh { background: var(--surface2); color: var(--text-muted); border: 1px solid var(--border); }
  .btn-refresh:hover { color: var(--text); border-color: var(--border-light); }
  .btn-refresh.spinning .refresh-icon { animation: spin 0.8s linear infinite; }
  .user-chip {
    display: flex; align-items: center; gap: 8px; background: var(--surface);
    border: 1px solid var(--border); border-radius: 999px; padding: 5px 14px 5px 5px;
    font-size: 0.78rem; color: var(--text-muted);
  }
  .user-avatar {
    width: 26px; height: 26px; border-radius: 50%;
    background: linear-gradient(135deg, #1877f2 0%, #e1306c 100%);
    color: #fff; font-size: 0.7rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }

  /* ── Main layout ──────────────────────────────────────── */
  .main { padding: 28px 32px 56px; max-width: 1400px; margin: 0 auto; }
  .section-head {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 14px;
    display: flex; align-items: center; gap: 8px;
  }
  .section-head::before { content: ''; width: 10px; height: 1px; background: var(--text-dim); }

  /* ── KPI cards ────────────────────────────────────────── */
  .kpi-grid {
    display: grid; grid-template-columns: repeat(6, 1fr);
    gap: 12px; margin-bottom: 28px;
  }
  @media (max-width: 1200px) { .kpi-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 700px)  { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }
  .kpi-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 18px 20px; position: relative; overflow: hidden;
  }
  .kpi-card::after {
    content: ''; position: absolute; inset: 0; opacity: 0.06;
    pointer-events: none;
  }
  .kpi-card.k-blue::after  { background: radial-gradient(circle at top right, var(--blue), transparent 70%); }
  .kpi-card.k-green::after { background: radial-gradient(circle at top right, var(--green), transparent 70%); }
  .kpi-card.k-gold::after  { background: radial-gradient(circle at top right, var(--gold), transparent 70%); }
  .kpi-card.k-pink::after  { background: radial-gradient(circle at top right, var(--pink), transparent 70%); }
  .kpi-card.k-cyan::after  { background: radial-gradient(circle at top right, var(--cyan), transparent 70%); }
  .kpi-card.k-purple::after{ background: radial-gradient(circle at top right, var(--purple), transparent 70%); }
  .kpi-label { font-size: 0.72rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
  .kpi-value { font-size: 1.6rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1; }
  .kpi-sub   { font-size: 0.72rem; color: var(--text-dim); margin-top: 6px; }

  /* ── Chart card ───────────────────────────────────────── */
  .chart-card {
    background: linear-gradient(180deg, var(--surface) 0%, var(--surface2) 100%);
    border: 1px solid var(--border); border-radius: 16px; padding: 22px 24px;
    margin-bottom: 28px;
  }
  .chart-title { font-size: 0.85rem; font-weight: 700; color: var(--text); margin-bottom: 16px; }
  .chart-wrap  { height: 280px; }

  /* ── Tables ───────────────────────────────────────────── */
  .table-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden; margin-bottom: 28px;
  }
  .table-toolbar {
    display: flex; align-items: center; gap: 14px; padding: 18px 20px;
    border-bottom: 1px solid var(--border); flex-wrap: wrap;
  }
  .table-title { font-size: 0.92rem; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 10px; }
  .count {
    font-size: 0.7rem; font-weight: 700; background: var(--blue-bg); color: var(--blue);
    border-radius: 999px; padding: 2px 8px;
  }
  .table-wrap { overflow-x: auto; max-height: 500px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.82rem; white-space: nowrap; }
  thead th {
    background: var(--surface2); padding: 13px 16px; text-align: left;
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--text-muted); cursor: pointer;
    position: sticky; top: 0; border-bottom: 1px solid var(--border); user-select: none;
  }
  thead th:hover { color: var(--text); }
  tbody tr { border-bottom: 1px solid rgba(39,45,68,0.5); transition: background 0.1s; }
  tbody tr:hover { background: var(--surface2); }
  td { padding: 12px 16px; color: var(--text-muted); }
  td.num { text-align: right; font-variant-numeric: tabular-nums; color: var(--text); }
  td.pos { color: var(--green); font-weight: 600; }
  .status-badge {
    display: inline-flex; align-items: center; gap: 5px; font-size: 0.7rem;
    font-weight: 700; padding: 3px 8px; border-radius: 6px; border: 1px solid transparent;
  }
  .status-active  { background: var(--green-bg); color: var(--green); border-color: rgba(52,211,153,0.2); }
  .status-paused  { background: var(--gold-bg);  color: var(--gold);  border-color: rgba(251,191,36,0.2); }
  .status-other   { background: var(--surface3); color: var(--text-muted); border-color: var(--border); }
  .empty { text-align: center; padding: 60px 20px; color: var(--text-muted); font-size: 0.9rem; }
  .error { color: var(--red); }
</style>
</head>
<body data-state="loading">

<!-- Boot / loading -->
<div id="boot" class="full-center">
  <div style="text-align:center;">
    <div class="spinner" style="margin:0 auto 16px;"></div>
    <div style="color:var(--text-muted); font-size:0.85rem;">Loading…</div>
  </div>
</div>

<!-- Login -->
<div id="login" class="full-center">
  <form class="auth-card" id="loginForm">
    <div class="auth-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
    </div>
    <h1>Meta Ads Dashboard</h1>
    <p class="sub">Sign in to view your ad performance</p>
    <input class="auth-input" type="email" id="email" placeholder="you@example.com" required autocomplete="email">
    <input class="auth-input" type="password" id="password" placeholder="Password" required autocomplete="current-password" style="margin-top:10px;">
    <button type="submit" class="auth-btn" id="sendBtn">Sign In</button>
    <div class="auth-error" id="loginError"></div>
  </form>
</div>

<!-- Access denied -->
<div id="denied" class="full-center">
  <div class="auth-card" style="text-align:center;">
    <div style="font-size:2.5rem; margin-bottom:16px;">🔒</div>
    <h1 style="font-size:1.2rem; margin-bottom:8px;">Access Denied</h1>
    <p class="sub" style="margin-bottom:20px;">You don't have permission to view the Meta Ads dashboard. Contact your admin to request access.</p>
